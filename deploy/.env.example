# vLLM NVFP4 deployment configuration
# Copy to .env and edit values before running docker compose up

# --- Required ---
# HuggingFace model ID or local path (mounted via HF_CACHE volume)
MODEL_ID=your-username/Your-Model-NVFP4

# --- Optional: Authentication ---
# HuggingFace token (only needed for gated/private models)
# HF_TOKEN=hf_xxxxx

# --- Optional: Container ---
CONTAINER_NAME=vllm-nvfp4
VLLM_IMAGE=vllm/vllm-openai:cu130-nightly
PORT=8000

# --- Optional: Cache paths ---
# Host paths for persistent caching
HF_CACHE=~/.cache/huggingface
VLLM_CACHE=~/.cache/vllm

# --- Optional: Model serving ---
# Max context length (tokens)
MAX_MODEL_LEN=262144
# Fraction of GPU memory to use for model + KV cache
GPU_MEMORY_UTILIZATION=0.8
# Max concurrent sequences
MAX_NUM_SEQS=4
# Max tokens per batch
MAX_NUM_BATCHED_TOKENS=4096
# KV cache precision (fp8 saves ~50% KV memory)
KV_CACHE_DTYPE=fp8

# --- Optional: NVFP4 backend ---
# marlin (default) or cutlass
NVFP4_BACKEND=marlin

# --- Optional: Tool/reasoning parsing ---
REASONING_PARSER=qwen3
TOOL_CALL_PARSER=qwen3_coder
